# ========================================
# Application
# ========================================
PROJECT_NAME=Vault API
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=False
API_V1_PREFIX=/api/v1

# ========================================
# Security - CRITICAL: Generate secure random keys!
# ========================================
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production

# Generate MASTER_ENCRYPTION_KEY: python scripts/generate_master_key.py
MASTER_ENCRYPTION_KEY=your-base64-master-key-here-change-this-in-production

# ========================================
# Database
# ========================================
DATABASE_URL=postgresql+asyncpg://vault_user:vault_password@localhost:5432/vault_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=False

# ========================================
# Redis
# ========================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ========================================
# CORS
# ========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========================================
# Features
# ========================================
ENABLE_REGISTRATION=True
AUDIT_LOG_ENABLED=True
